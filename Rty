<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>หนองถ้ำคำถาม โดย เวียร์-วีรภัทร</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

body{
font-family:sans-serif;
background:#0f172a;
color:white;
text-align:center;
margin:0;
padding:20px;
}

h1{
font-size:28px;
}

button{
display:block;
width:90%;
max-width:300px;
margin:10px auto;
padding:12px;
border:none;
border-radius:8px;
background:#3b82f6;
color:white;
font-size:16px;
}

button:hover{
background:#2563eb;
}

#notMobile{
display:none;
margin-top:100px;
}

</style>
</head>

<body>

<div id="mobileOnly">

<h1>หนองถ้ำคำถาม</h1>
<h3>โดย เวียร์-วีรภัทร</h3>

<div id="quiz">

<h2 id="question"></h2>

<div id="answers"></div>

</div>

</div>

<div id="notMobile">
<h2>เกมนี้เล่นได้เฉพาะมือถือ 📱</h2>
</div>

<script>

// ตรวจสอบมือถือ
if(!/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)){
document.getElementById("mobileOnly").style.display="none"
document.getElementById("notMobile").style.display="block"
}

// คำถาม
let questions=[

{q:"2+2=?",a:["3","4","5","6"],c:1},

{q:"Hello ภาษาไทย?",a:["สวัสดี","ขอบคุณ","ลาก่อน","กิน"],c:0},

{q:"Lua ใช้คำสั่งอะไรแสดงข้อความ",a:["print()","echo()","say()","show()"],c:0},

{q:"โลกหมุนรอบอะไร",a:["ดวงจันทร์","ดวงอาทิตย์","ดาวอังคาร","ดาว"],c:1},

{q:"แมว ภาษาอังกฤษ?",a:["dog","cat","bird","fish"],c:1}

]

// เพิ่มคำถามสุ่มให้ครบ 50
for(let i=6;i<=50;i++){

questions.push({

q:"คำถามข้อ "+i,

a:["A","B","C","D"],

c:Math.floor(Math.random()*4)

})

}

let current=0
let score=0

function load(){

let q=questions[current]

document.getElementById("question").innerText=q.q

let html=""

for(let i=0;i<4;i++){

html+=`<button onclick="answer(${i})">${q.a[i]}</button>`

}

document.getElementById("answers").innerHTML=html

}

function answer(i){

if(i==questions[current].c){

score++

}

current++

if(current>=questions.length){

document.getElementById("quiz").innerHTML=

"<h2>จบเกม</h2>"+
"<p>คะแนน: "+score+" / "+questions.length+"</p>"+
"<button onclick='location.reload()'>เล่นใหม่</button>"

}else{

load()

}

}

load()

</script>

</body>
</html>
